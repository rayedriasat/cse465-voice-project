# ── Fix the flattened config by splitting on known rclone keys ───────────────
# Kaggle Secrets strips newlines, so "[gdrive] type = drive" arrives as one line.
# We reconstruct proper INI format by inserting newlines before each key.

import re

raw = RCLONE_CONF.strip()

# Insert newline before section headers like [gdrive]
raw = re.sub(r'\s*(\[[^\]]+\])\s*', r'\n\1\n', raw)

# Insert newline before each "key = value" pair
# rclone keys are lowercase words: type, scope, token, team_drive, etc.
raw = re.sub(r'\s+(type|scope|token|team_drive|client_id|client_secret|'
             r'root_folder_id|service_account_file|drive_id)\s*=\s*',
             r'\n\1 = ', raw)

# Clean up any leading blank lines
raw = raw.strip() + '\n'

rclone_cfg = pathlib.Path.home() / '.config/rclone/rclone.conf'
rclone_cfg.parent.mkdir(parents=True, exist_ok=True)
rclone_cfg.write_text(raw)

